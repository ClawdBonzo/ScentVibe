        "de": { "stringUnit": { "state": "translated", "value": "Die Zahlung wird bei Bestätigung über deine Apple-ID abgerechnet. Das Abo verlängert sich automatisch, sofern es nicht mindestens 24 Stunden vor Ablauf des Zeitraums gekündigt wird." } },
        "it": { "stringUnit": { "state": "translated", "value": "Il pagamento verrà addebitato sul tuo ID Apple alla conferma. L'abbonamento si rinnova automaticamente salvo disdetta almeno 24 ore prima della scadenza del periodo in corso." } },
        "es": { "stringUnit": { "state": "translated", "value": "El pago se cargará a tu ID de Apple al confirmar. La suscripción se renueva automáticamente, salvo cancelación al menos 24 horas antes del fin del período actual." } }
