{
  "sourceLanguage": "en",
  "strings": {
    "onboarding_title_1": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Snap Your Style" } },
        "de": { "stringUnit": { "state": "translated", "value": "Fange deinen Stil ein" } },
        "es-MX": { "stringUnit": { "state": "translated", "value": "Captura tu Estilo" } },
        "pt-BR": { "stringUnit": { "state": "translated", "value": "Capture seu Estilo" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Captez votre Style" } }
      }
    },
    "onboarding_subtitle_1": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Take a photo of your outfit or room and let AI analyze your visual vibe" } },
        "de": { "stringUnit": { "state": "translated", "value": "Mach ein Foto deines Outfits oder Raums und lass die KI deine visuelle Stimmung analysieren" } },
        "es-MX": { "stringUnit": { "state": "translated", "value": "Toma una foto de tu outfit o habitacion y deja que la IA analice tu vibra visual" } },
        "pt-BR": { "stringUnit": { "state": "translated", "value": "Tire uma foto do seu look ou ambiente e deixe a IA analisar sua vibe visual" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Prenez une photo de votre tenue ou piece et laissez l'IA analyser votre ambiance visuelle" } }
      }
    },
    "onboarding_title_2": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Instant Scent Match" } },
        "de": { "stringUnit": { "state": "translated", "value": "Sofortiger Duft-Match" } },
        "es-MX": { "stringUnit": { "state": "translated", "value": "Match de Aroma Instantaneo" } },
        "pt-BR": { "stringUnit": { "state": "translated", "value": "Combinacao de Aroma Instantanea" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Match Parfum Instantane" } }
      }
    },
    "onboarding_subtitle_2": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Our engine matches your colors, mood, and style to the perfect fragrance from 86+ curated scents" } },
        "de": { "stringUnit": { "state": "translated", "value": "Unsere Engine matched deine Farben, Stimmung und Stil mit dem perfekten Duft aus 86+ kuratierten Duften" } },
        "es-MX": { "stringUnit": { "state": "translated", "value": "Nuestro motor combina tus colores, estado de animo y estilo con la fragancia perfecta de mas de 86 aromas curados" } },
        "pt-BR": { "stringUnit": { "state": "translated", "value": "Nosso motor combina suas cores, humor e estilo com a fragrancia perfeita de mais de 86 aromas curados" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Notre moteur associe vos couleurs, humeur et style au parfum parfait parmi plus de 86 fragrances selectionnees" } }
      }
    },
    "onboarding_title_3": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Discover & Collect" } },
        "de": { "stringUnit": { "state": "translated", "value": "Entdecken & Sammeln" } },
        "es-MX": { "stringUnit": { "state": "translated", "value": "Descubre y Colecciona" } },
        "pt-BR": { "stringUnit": { "state": "translated", "value": "Descubra e Colecione" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Decouvrez et Collectionnez" } }
      }
    },
    "onboarding_subtitle_3": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Build your scent wardrobe, explore fragrances from 5 cultures, and shop your favorites" } },
        "de": { "stringUnit": { "state": "translated", "value": "Erstelle deine Duft-Garderobe, entdecke Duefte aus 5 Kulturen und kaufe deine Favoriten" } },
        "es-MX": { "stringUnit": { "state": "translated", "value": "Construye tu guardarropa de aromas, explora fragancias de 5 culturas y compra tus favoritos" } },
        "pt-BR": { "stringUnit": { "state": "translated", "value": "Monte seu guarda-roupa de aromas, explore fragancias de 5 culturas e compre seus favoritos" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Construisez votre garde-robe olfactive, explorez des parfums de 5 cultures et achetez vos favoris" } }
      }
    },
    "onboarding_start": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Start Scanning" } },
        "de": { "stringUnit": { "state": "translated", "value": "Jetzt scannen" } },
        "es-MX": { "stringUnit": { "state": "translated", "value": "Comenzar a Escanear" } },
        "pt-BR": { "stringUnit": { "state": "translated", "value": "Comecar a Escanear" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Commencer le Scan" } }
      }
    },
    "onboarding_next": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Next" } },
        "de": { "stringUnit": { "state": "translated", "value": "Weiter" } },
