        "pt-BR": { "stringUnit": { "state": "translated", "value": "Proximo" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Suivant" } }
      }
    },
    "onboarding_skip": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Skip" } },
