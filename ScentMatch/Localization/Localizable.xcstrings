    "scan_subtitle": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Snap a photo of your outfit or room\nand discover your perfect fragrance" } },
        "de": { "stringUnit": { "state": "translated", "value": "Mach ein Foto deines Outfits oder Raums\nund entdecke deinen perfekten Duft" } },
        "es-MX": { "stringUnit": { "state": "translated", "value": "Toma una foto de tu outfit o habitacion\ny descubre tu fragancia perfecta" } },
        "pt-BR": { "stringUnit": { "state": "translated", "value": "Tire uma foto do seu look ou ambiente\ne descubra sua fragrancia perfeita" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Prenez une photo de votre tenue ou piece\net decouvrez votre parfum ideal" } }
